  "substitutions": [
    "SRC_ADDR -> IPV4_SRC_ADDR (standard NetFlow v3 naming)",
    "DST_ADDR -> IPV4_DST_ADDR (standard NetFlow v3 naming)",
    "SRC_PORT -> L4_SRC_PORT (Layer 4 source port)",
    "DST_PORT -> L4_DST_PORT (Layer 4 destination port)",
    "SRC_IAT_MAX -> SRC_TO_DST_IAT_MAX (inter-arrival time max, src to dst)",
