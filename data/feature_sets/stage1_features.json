    "DST_ADDR": "IPV4_DST_ADDR",
    "SRC_PORT": "L4_SRC_PORT",
    "DST_PORT": "L4_DST_PORT",
    "PROTOCOL": "PROTOCOL",
    "FLOW_DURATION_MILLISECONDS": "FLOW_DURATION_MILLISECONDS",
    "SRC_IAT_MAX": "SRC_TO_DST_IAT_MAX",
    "DST_IAT_MAX": "DST_TO_SRC_IAT_MAX",
